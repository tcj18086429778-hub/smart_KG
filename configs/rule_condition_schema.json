{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "smart_KG rule condition",
  "oneOf": [
    {
      "type": "object",
      "required": ["field", "operator"],
      "properties": {
        "field": {"type": "string"},
        "operator": {"enum": ["eq", "neq", "in", "not_in", "is_null", "exists", "gt", "gte", "lt", "lte"]},
        "value": {}
      }
    },
    {
      "type": "object",
      "required": ["logic", "conditions"],
      "properties": {
        "logic": {"enum": ["AND", "OR"]},
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#"}
        }
      }
    }
  ]
}
